{
  "extends": ["next/core-web-vitals", "prettier"],
  "plugins": ["resovo"],
  "ignorePatterns": ["apps/**/templates/**", ".next/**", "node_modules/**", "tools/eslint-plugin-resovo/**"],
  "rules": {
    "no-console": "error",
    "resovo/no-hardcoded-color": "error"
  },
  "overrides": [
    {
      "files": [
        "apps/web-next/src/app/**/*.ts",
        "apps/web-next/src/app/**/*.tsx",
        "apps/web-next/src/components/**/*.ts",
        "apps/web-next/src/components/**/*.tsx",
        "apps/web-next/src/lib/**/*.ts",
        "apps/web-next/src/lib/**/*.tsx",
        "apps/web-next/src/stores/**/*.ts",
        "apps/web-next/src/stores/**/*.tsx"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/api/*", "@/api/**"],
                "message": "[DEC-01] 前台代码禁止直接 import @/api/**（后端实现层）。请改用 @/types/contracts/v1/ 中的共享类型，或通过 @/lib/api-client 发起 HTTP 请求。"
              }
            ]
          }
        ]
      }
    }
  ]
}
