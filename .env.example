# Resovo（流光） 环境变量示例
# 复制此文件为 .env.local 并填写实际值

# ── 数据库 ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/resovo_dev

# ── Elasticsearch ─────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT 和 Cookie ─────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-32-chars
COOKIE_SECRET=your-cookie-secret-at-least-32-chars

# ── 前端公开变量（可被浏览器访问）─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── 服务端口 ──────────────────────────────────────────────────────
PORT=4000

# ── 环境 ──────────────────────────────────────────────────────────
NODE_ENV=development

# ── 开发快捷登录（仅本地开发）─────────────────────────────────────
# 开启登录页“开发快速登录”按钮（true/false）
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false
# 前端携带的开发登录鉴权头（仅本地使用）
NEXT_PUBLIC_DEV_LOGIN_SECRET=change-me-dev-login-secret
# 后端校验的开发登录鉴权密钥（需与上方一致）
DEV_LOGIN_SECRET=change-me-dev-login-secret
# 可选：默认开发登录账号（用户名或邮箱）
DEV_LOGIN_IDENTIFIER=admin

# ── 爬虫资源站（逗号分隔 JSON，或单个 URL） ───────────────────────
# CRAWLER_SOURCES=[{"name":"jsm3u8","base":"https://jszyapi.com","format":"json","enabled":true}]

# ── 爬虫采集后自动上架（仅开发/测试环境设为 true，生产保持 false）───
AUTO_PUBLISH_CRAWLED=false

# ── Cloudflare R2（字幕存储）────────────────────────────────────────
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET=resovo-subtitles
