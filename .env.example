# Resovo（流光） 环境变量示例
# 复制此文件为 .env.local 并填写实际值

# ── 数据库 ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/resovo_dev

# ── Elasticsearch ─────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT 和 Cookie ─────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-32-chars
COOKIE_SECRET=your-cookie-secret-at-least-32-chars

# ── 前端公开变量（可被浏览器访问）─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── 服务端口 ──────────────────────────────────────────────────────
PORT=4000

# ── 环境 ──────────────────────────────────────────────────────────
NODE_ENV=development

# ── 开发快捷登录（仅本地开发）─────────────────────────────────────
# 开启登录页“开发快速登录”按钮（true/false）
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false
# 前端携带的开发登录鉴权头（仅本地使用）
NEXT_PUBLIC_DEV_LOGIN_SECRET=change-me-dev-login-secret
# 后端校验的开发登录鉴权密钥（需与上方一致）
DEV_LOGIN_SECRET=change-me-dev-login-secret
# 可选：默认开发登录账号（用户名或邮箱）
DEV_LOGIN_IDENTIFIER=admin

# ── 爬虫资源站（逗号分隔 JSON，或单个 URL） ───────────────────────
# CRAWLER_SOURCES=[{"name":"jsm3u8","base":"https://jszyapi.com","format":"json","enabled":true}]

# ── 爬虫采集后自动上架（仅开发/测试环境设为 true，生产保持 false）───
AUTO_PUBLISH_CRAWLED=false

# ── Cloudflare R2（字幕 + 图片存储）──────────────────────────────────
# R2 账号凭据字幕与图片共享；bucket 分两个便于独立 lifecycle / CDN 规则
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET=resovo-subtitles           # 字幕 bucket（SubtitleService）
# R2_IMAGES_BUCKET=resovo-images       # 图片 bucket（IMG-06 ImageStorageService）
#
# R2_PUBLIC_BASE_URL — 前台可直接访问的公开资源域名（R2.dev 子域名 / CNAME / CF Images fetch 源）
# 未设置时 ImageStorageService 回退 R2_ENDPOINT（S3 API endpoint），浏览器 <img src> 会加载失败
# 生产必须配置，例：
# R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev            # R2.dev 公开子域名
# R2_PUBLIC_BASE_URL=https://images.resovo.com           # 绑定的自定义域名
#
# ── 本地 FS Fallback（R2 三件套未配时启用，仅开发环境）─────────────────
# ImageStorageService 在 R2 未配时自动切到本地 FS provider，上传写入 LOCAL_UPLOAD_DIR
# 前台通过 LOCAL_UPLOAD_PUBLIC_URL 访问，由 apps/api 内置 GET /v1/uploads/* 路由返回文件
# LOCAL_UPLOAD_DIR=.uploads                                # 相对 apps/api 工作目录
# LOCAL_UPLOAD_PUBLIC_URL=http://localhost:3001/v1/uploads # 本地 dev server 地址

# ── 图片 CDN Loader（CDN-01 / frontend_redesign §F3 Cloudflare Images 定稿）────
# apps/web-next 的 SafeImage 与 next/image 都走 src/lib/image/image-loader.ts 的 getLoader()
# 默认 passthrough：原图 URL 直出，不经 CDN；适用于本地开发与未接 CF 的过渡期
# 切换到 cloudflare 需同时填入 account hash
#
# server/edge 运行时（app/*/route.ts、middleware、RSC）读这组：
# IMAGE_LOADER=passthrough
# IMAGE_LOADER_CF_ACCOUNT_HASH=
#
# client 组件（'use client'，编译期注入）读这组：
# NEXT_PUBLIC_IMAGE_LOADER=passthrough
# NEXT_PUBLIC_IMAGE_LOADER_CF_ACCOUNT_HASH=
