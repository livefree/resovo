{
  "name": "resovo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/api",
    "apps/server",
    "apps/server-next",
    "apps/web-next",
    "apps/worker",
    "packages/admin-ui",
    "packages/design-tokens",
    "packages/logger",
    "packages/player",
    "packages/player-core",
    "packages/types",
    "tools/eslint-plugin-resovo"
  ],
  "scripts": {
    "predev": "npm run migrate:check --silent || true",
    "dev": "node scripts/dev.mjs",
    "dev:turbo": "npx turbo dev",
    "api": "node --env-file=.env.local --import tsx --watch apps/api/src/server.ts",
    "build": "npx turbo build",
    "start": "npx turbo start",
    "typecheck": "tsc --noEmit && npm --workspace @resovo/server run typecheck && npm --workspace @resovo/server-next run typecheck && npm --workspace @resovo/web-next run typecheck && npm --workspace @resovo/player-core run typecheck && npm --workspace @resovo/design-tokens run typecheck && npm --workspace @resovo/admin-ui run typecheck && npm --workspace @resovo/worker run typecheck",
    "dev:server-next": "npm --workspace @resovo/server-next run dev",
    "lint": "npx turbo lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:changed": "node scripts/test-changed.mjs",
    "test:changed:main": "node scripts/test-changed.mjs --base origin/main",
    "test:integration": "node --env-file=.env.local node_modules/.bin/vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test --project=admin-chromium --project=admin-next-chromium --project=web-chromium --project=web-mobile",
    "test:e2e:ui": "playwright test --ui --project=admin-chromium --project=admin-next-chromium --project=web-chromium --project=web-mobile",
    "test:visual": "PLAYWRIGHT_VISUAL=1 playwright test --project=admin-visual",
    "test:visual:update": "PLAYWRIGHT_VISUAL=1 playwright test --project=admin-visual --update-snapshots=all",
    "preflight": "bash scripts/preflight.sh",
    "preflight:e2e": "bash scripts/preflight.sh --with-e2e",
    "verify:docs-format": "bash scripts/check-docs-format.sh",
    "verify:admin-guardrails": "node scripts/verify-admin-guardrails.mjs --staged",
    "verify:server-next-isolation": "node scripts/verify-server-next-isolation.mjs",
    "verify:token-isolation": "node scripts/verify-token-isolation.mjs",
    "verify:token-references": "node scripts/verify-token-references.mjs",
    "verify:no-bare-backdrop": "node scripts/verify-no-bare-backdrop.mjs",
    "verify:admin-guardrails:all": "node scripts/verify-admin-guardrails.mjs --all",
    "verify:endpoint-adr": "node scripts/verify-endpoint-adr.mjs",
    "verify:error-message": "node scripts/verify-error-message.mjs",
    "verify:adr-d-numbers": "node scripts/verify-adr-d-numbers.mjs",
    "verify:admin-shell-types-mirror": "node scripts/verify-admin-shell-types-mirror.mjs",
    "verify:enum-ssot": "node scripts/verify-enum-ssot.mjs",
    "verify:adr-contracts": "node scripts/verify-endpoint-adr.mjs && node scripts/verify-error-message.mjs && node scripts/verify-adr-d-numbers.mjs && node scripts/verify-sql-schema-alignment.mjs && node scripts/verify-style-shorthand-conflict.mjs && node scripts/verify-admin-shell-types-mirror.mjs && node scripts/verify-enum-ssot.mjs",
    "verify:sql-schema-alignment": "node scripts/verify-sql-schema-alignment.mjs",
    "verify:style-shorthand-conflict": "node scripts/verify-style-shorthand-conflict.mjs",
    "verify:file-size-budget": "node scripts/verify-file-size-budget.mjs",
    "verify:manual-coverage": "node scripts/verify-manual-coverage.mjs",
    "migrate": "node --env-file=.env.local --import tsx scripts/migrate.ts",
    "migrate:check": "node --env-file=.env.local --import tsx scripts/migrate.ts --dry-run",
    "clear:crawled-data": "node --env-file=.env.local --import tsx scripts/clear-crawled-data.ts",
    "import:sources": "node --env-file=.env.local --import tsx scripts/import-sources.ts",
    "create:admin": "node --env-file=.env.local --import tsx scripts/create-admin.ts",
    "verify:crawler": "node --env-file=.env.local --import tsx scripts/verify-crawler.ts",
    "test:crawler-site": "node --env-file=.env.local --import tsx scripts/test-crawler-site.ts",
    "crawler:stop-all": "node --env-file=.env.local --import tsx scripts/stop-all-crawls.ts",
    "verify:baseline": "tsx scripts/verify-baseline.ts",
    "test:guarded": "tsx scripts/test-guarded.ts",
    "test:guarded:e2e": "tsx scripts/test-guarded.ts --mode e2e",
    "test:guarded:all": "tsx scripts/test-guarded.ts --mode all",
    "logs": "tail -F logs/dev/*.log",
    "logs:errors": "tail -F logs/errors/*.ndjson"
  },
  "dependencies": {
    "@resovo/player": "*",
    "@resovo/types": "*",
    "@aws-sdk/client-s3": "^3.717.0",
    "@elastic/elasticsearch": "^8.16.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.0",
    "autoprefixer": "^10.4.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.0",
    "clsx": "^2.1.0",
    "comment-core-library": "^0.11.1",
    "dayjs": "^1.11.13",
    "douban-adapter": "file:external-adapter/douban-adapter",
    "fastify": "^4.29.0",
    "pino": "^9.0.0",
    "fastify-type-provider-zod": "^1.1.9",
    "hls.js": "^1.6.15",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "next": "^15.1.0",
    "next-intl": "^3.26.0",
    "pg": "^8.13.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "striptags": "^3.2.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "utility-types": "^3.11.0",
    "zod": "^3.24.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-resovo": "*",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
