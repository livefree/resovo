{
  "name": "resovo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx turbo dev",
    "api": "node --env-file=.env.local --import tsx --watch apps/api/src/server.ts",
    "build": "npx turbo build",
    "start": "npx turbo start",
    "typecheck": "tsc --noEmit && npm --workspace @resovo/server run typecheck",
    "lint": "npx turbo lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preflight": "bash scripts/preflight.sh",
    "preflight:e2e": "bash scripts/preflight.sh --with-e2e",
    "verify:docs-format": "bash scripts/check-docs-format.sh",
    "verify:admin-guardrails": "node scripts/verify-admin-guardrails.mjs --staged",
    "verify:admin-guardrails:all": "node scripts/verify-admin-guardrails.mjs --all",
    "migrate": "node --env-file=.env.local --import tsx scripts/migrate.ts",
    "clear:crawled-data": "node --env-file=.env.local --import tsx scripts/clear-crawled-data.ts",
    "import:sources": "node --env-file=.env.local --import tsx scripts/import-sources.ts",
    "create:admin": "node --env-file=.env.local --import tsx scripts/create-admin.ts",
    "verify:crawler": "node --env-file=.env.local --import tsx scripts/verify-crawler.ts",
    "test:crawler-site": "node --env-file=.env.local --import tsx scripts/test-crawler-site.ts",
    "crawler:stop-all": "node --env-file=.env.local --import tsx scripts/stop-all-crawls.ts"
  },
  "dependencies": {
    "@resovo/player": "*",
    "@resovo/types": "*",
    "@aws-sdk/client-s3": "^3.717.0",
    "@elastic/elasticsearch": "^8.16.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.0",
    "autoprefixer": "^10.4.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.0",
    "clsx": "^2.1.0",
    "comment-core-library": "^0.11.1",
    "dayjs": "^1.11.13",
    "douban-adapter": "file:external-adapter/douban-adapter",
    "fastify": "^4.29.0",
    "fastify-type-provider-zod": "^1.1.9",
    "hls.js": "^1.6.15",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "next": "^15.1.0",
    "next-intl": "^3.26.0",
    "pg": "^8.13.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "striptags": "^3.2.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "utility-types": "^3.11.0",
    "zod": "^3.24.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
