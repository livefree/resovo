{
  "name": "@resovo/design-tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": ["./src/css/*.css", "./dist/tokens.css"],
  "exports": {
    "./css": {
      "default": "./src/css/tokens.css"
    },
    "./dist/css": {
      "default": "./dist/tokens.css"
    },
    "./js": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dist/js": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./brands": {
      "types": "./src/brands/index.ts",
      "default": "./src/brands/index.ts"
    }
  },
  "scripts": {
    "clean": "node -e \"const {rmSync,existsSync}=require('fs');if(existsSync('dist'))rmSync('dist',{recursive:true})\"",
    "prebuild": "npm run clean -w @resovo/design-tokens || true",
    "build": "tsx build.ts && tsx scripts/build-css.ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx scripts/build-css.ts --watch",
    "tokens:validate": "tsx scripts/validate-tokens.ts"
  },
  "devDependencies": {
    "typescript": "*"
  }
}
